# SkillGap.AI — Environment Variables
# Copy this to .env.local and fill in values

# Optional: Python API backend URL
# If not set, all analysis runs locally in the browser (no backend needed)
# Set this if you deploy the FastAPI backend separately (e.g. Railway, Render)
NEXT_PUBLIC_API_URL=

# Example for Railway:
# NEXT_PUBLIC_API_URL=https://skillgap-api.railway.app
